{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/hiku-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Satoshi|Architects Daughter))/i]",
        "message": "Font not provided by the design system. Available: Satoshi, Architects Daughter."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:logoSrc|height|align|children|style|key|ref|className|style|children)$/]",
        "message": "<AppHeader> doesn't accept that prop. Declared props: logoSrc, height, align, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AppHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<AppHeader> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='NavTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|avatar|key|ref|className|style|children)$/]",
        "message": "<NavTab> doesn't accept that prop. Declared props: id, label, icon, avatar."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|fullWidth|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, fullWidth, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|vibrant)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'vibrant'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommunityCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|description|members|compact|joined|onJoin|onKnowMore|style|key|ref|className|style|children)$/]",
        "message": "<CommunityCard> doesn't accept that prop. Declared props: image, title, description, members, compact, joined, onJoin, onKnowMore, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|dropdown|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: children, dropdown, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute[name.name='name'] > Literal[value!=/^(?:search|sliders-horizontal|sliders-vertical|chevron-down|arrow-left|map|compass|globe|shopping-bag|user|layers|navigation|tent|caravan|house|heart|star|map-pin|plus|minus|check|x|mountain)$/]",
        "message": "<Icon> name must be one of 'search' | 'sliders-horizontal' | 'sliders-vertical' | 'chevron-down' | 'arrow-left' | 'map' | 'compass' | 'globe' | 'shopping-bag' | 'user' | 'layers' | 'navigation' | 'tent' | 'caravan' | 'house' | 'heart' | 'star' | 'map-pin' | 'plus' | 'minus' | 'check' | 'x' | 'mountain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|shape|variant|size|iconSize|active|disabled|onClick|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: icon, shape, variant, size, iconSize, active, disabled, onClick, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:square|round)$/]",
        "message": "<IconButton> shape must be one of 'square' | 'round'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|float|plain|brand)$/]",
        "message": "<IconButton> variant must be one of 'outline' | 'float' | 'plain' | 'brand'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Illustration'] > JSXAttribute > JSXIdentifier[name!=/^(?:scene|tone|height|style|key|ref|className|style|children)$/]",
        "message": "<Illustration> doesn't accept that prop. Declared props: scene, tone, height, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Illustration'] > JSXAttribute[name.name='scene'] > Literal[value!=/^(?:mountains|tent|forest|trail|campfire|lake)$/]",
        "message": "<Illustration> scene must be one of 'mountains' | 'tent' | 'forest' | 'trail' | 'campfire' | 'lake'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Illustration'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|deep|soft)$/]",
        "message": "<Illustration> tone must be one of 'green' | 'deep' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|type|label|disabled|onChange|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: value, defaultValue, placeholder, type, label, disabled, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|wordmark|height|color|style|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: src, wordmark, height, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MapMarker'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|active|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<MapMarker> doesn't accept that prop. Declared props: icon, active, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OptionRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|subtitle|selected|onClick|style|key|ref|className|style|children)$/]",
        "message": "<OptionRow> doesn't accept that prop. Declared props: icon, title, subtitle, selected, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|meta|rating|price|priceUnit|saved|onSave|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PlaceCard> doesn't accept that prop. Declared props: image, title, meta, rating, price, priceUnit, saved, onSave, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|onClick|style|key|ref|className|style|children)$/]",
        "message": "<SearchBar> doesn't accept that prop. Declared props: title, subtitle, onClick, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
